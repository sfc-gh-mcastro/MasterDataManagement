# =============================================================================
# SPB1-SPECIFIC TESTS — Norwegian format validation and org coverage
# =============================================================================

# Personnummer format
SSN format valid in FREG | SELECT COUNT(*) FROM MDM_DEV.MDM_RAW_v001.CRMI_RAW_TB_FREG WHERE SSN IS NOT NULL AND NOT REGEXP_LIKE(SSN, '^[0-9]{11}$') | 0
# Organization split
BANK golden records exist (AI) | SELECT COUNT(*) FROM MDM_DEV.MDM_AGG_v001.CRMA_AGG_DT_CUSTOMER_AI WHERE ORGANIZATION = 'BANK' | > 0
INS golden records exist (AI) | SELECT COUNT(*) FROM MDM_DEV.MDM_AGG_v001.CRMA_AGG_DT_CUSTOMER_AI WHERE ORGANIZATION = 'INS' | > 0
BANK golden records exist (FUZZY) | SELECT COUNT(*) FROM MDM_DEV.MDM_AGG_v001.CRMA_AGG_DT_CUSTOMER_FUZZY WHERE ORGANIZATION = 'BANK' | > 0
# Data steward queue
Steward queue not empty | SELECT COUNT(*) FROM MDM_DEV.MDM_AGG_v001.CRMA_AGG_DT_CUSTOMER_STEWARD_QUEUE_AI | > 0
# Cross-org
Cross-org customers exist | SELECT COUNT(*) FROM MDM_DEV.MDM_SRV_v001.CRMS_AGG_VW_CUSTOMER_360_CROSS_ORG | > 0
# Norwegian phone format
No invalid phone formats in BS | SELECT COUNT(*) FROM MDM_DEV.MDM_RAW_v001.CRMI_RAW_TB_BS WHERE PHONE IS NOT NULL AND NOT REGEXP_LIKE(PHONE, '^\\+47[0-9]{8}$') | 0
# Norwegian postnummer
No invalid postnummer in address | SELECT COUNT(*) FROM MDM_DEV.MDM_RAW_v001.CRMI_RAW_TB_ADDRESSES_FREG WHERE POSTNUMMER IS NOT NULL AND NOT REGEXP_LIKE(POSTNUMMER, '^[0-9]{4}$') | 0
# FREG records appear in both orgs (CROSS JOIN effect)
FREG feeds BANK pipeline | SELECT COUNT(*) FROM MDM_DEV.MDM_AGG_v001.CRMA_AGG_VW_CUSTOMER_UNION WHERE SOURCE_SYSTEM = 'FREG' AND ORGANIZATION = 'BANK' | > 0
FREG feeds INS pipeline | SELECT COUNT(*) FROM MDM_DEV.MDM_AGG_v001.CRMA_AGG_VW_CUSTOMER_UNION WHERE SOURCE_SYSTEM = 'FREG' AND ORGANIZATION = 'INS' | > 0
# Unmerge override table exists
Unmerge overrides table exists | SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA = 'MDM_AGG_v001' AND TABLE_NAME = 'CRMA_AGG_TB_UNMERGE_OVERRIDES' | 1
